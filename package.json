{
  "name": "mcpatt-cli",
  "version": "1.1.32",
  "description": "Transparent audit-trail proxy for MCP (Model Context Protocol) traffic",
  "bin": {
    "mcpatt-cli": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "audit", "logging", "proxy", "cli"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cross-spawn": "^7.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/cross-spawn": "^6.0.6",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}